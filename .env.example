# X (Twitter) API v2 認証情報
# developer.twitter.com → プロジェクト → App Settings → Keys and Tokens
# ※ App permissions を「Read and Write」にしてから Access Token を生成すること
X_API_KEY=your_api_key_here
X_API_SECRET=your_api_secret_here
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# Claude API
# console.anthropic.com で取得
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# サイトURL
SITE_URL=https://career-kentaro.com/mbti/
